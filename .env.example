# Database (MySQL connection string)
DATABASE_URL="mysql://<user>:<password>@<host>:3306/<dbname>"

# Email (Resend API key - get from resend.com)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Site URLs
NEXT_PUBLIC_SITE_URL=https://bitsolmarketing.com
NEXT_PUBLIC_API_URL=https://admin.bitsolmarketing.com

# FTP Deployment (only needed if using deploy.mjs for FTP upload)
FTP_HOST=ftp.bitsolmarketing.com
FTP_USER=your-ftp-username
FTP_PASSWORD=your-ftp-password
