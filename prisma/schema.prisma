generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  courses   Course[] @relation(fields: [courseIds], references: [id])
  courseIds String[] @db.ObjectId
}

enum Role {
  STUDENT
  ADMIN
  CLIENT
}

model Course {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  price       Float
  image       String
  students    User[]   @relation(fields: [studentIds], references: [id])
  studentIds  String[] @db.ObjectId
  createdAt   DateTime @default(now())
}

model Blog {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  content         String
  slug            String   @unique
  author          String
  image           String?
  excerpt         String?
  metaDescription String?
  tags            String[]
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Lead {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("NEW")
  createdAt DateTime @default(now())
}
